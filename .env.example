# PostgreSQL connection string, ví dụ:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres
DATABASE_URL=

# Port cho backend API (mặc định 3000, frontend Vite sẽ proxy /api/* sang port này)
PORT=3000

# Mục tiêu cả năm (dùng để tính % kế hoạch)
KE_HOACH_SAN_LUONG=1000000
KE_HOACH_TIEN_DO=12000
